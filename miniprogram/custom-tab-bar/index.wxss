.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 112rpx;
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 999;
}

.safe-area {
  padding-bottom: env(safe-area-inset-bottom);
}

.item {
  position: relative;
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(0, 0, 0, 0.55);
  font-size: 28rpx;
}

.item.active {
  color: #0E8946;
  font-weight: 600;
}

/* Image-based icons (PNG from /assets/tab/) */
.icon-img {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
}

/* Text-based icon fallback (e.g. family tab) */
.icon-text {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.dot {
  position: absolute;
  top: 10rpx;
  right: 36rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
  transform: translateX(50%);
}

.text {
  line-height: 1;
}
