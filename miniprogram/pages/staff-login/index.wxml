<view class="page">
  <view class="hero">
    <view class="eyebrow">工作人员入口</view>
    <view class="title">手机号密码登录</view>
    <view class="sub">使用后台配置的工作人员手机号和初始密码登录，进入专用工作台。</view>
  </view>

  <view class="card">
    <view class="field">
      <view class="fieldLabel">手机号</view>
      <input
        class="fieldInput"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        placeholder-class="fieldPlaceholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="field fieldLast">
      <view class="fieldLabel">密码</view>
      <input
        class="fieldInput"
        password
        maxlength="32"
        placeholder="请输入初始密码或重置后的密码"
        placeholder-class="fieldPlaceholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>
  </view>

  <button class="submitBtn" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmit">登录并进入工作台</button>
  <button class="backBtn" disabled="{{loading}}" bindtap="onBack">返回我的页面</button>
</view>