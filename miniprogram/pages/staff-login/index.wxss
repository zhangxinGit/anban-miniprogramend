.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 34rpx 24rpx 120rpx;
  background:
    radial-gradient(circle at top right, rgba(231, 246, 235, 0.95), rgba(231, 246, 235, 0) 34%),
    linear-gradient(180deg, #f6faf5 0%, #eef6f0 100%);
}

.hero {
  padding: 12rpx 4rpx 30rpx;
}

.eyebrow {
  font-size: 22rpx;
  line-height: 1;
  color: #15934d;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1.2;
  color: #16311e;
  font-weight: 900;
}

.sub {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667267;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.1);
  box-shadow: 0 18rpx 50rpx rgba(15, 64, 35, 0.08);
  padding: 10rpx 24rpx;
}

.field {
  padding: 24rpx 6rpx 20rpx;
  border-bottom: 1rpx solid #edf1ec;
}

.fieldLast {
  border-bottom: 0;
}

.fieldLabel {
  font-size: 22rpx;
  color: #8f9791;
  font-weight: 700;
}

.fieldInput {
  margin-top: 24rpx;
  min-height: 52rpx;
  font-size: 30rpx;
  line-height: 52rpx;
  color: #1f2a20;
}

.fieldPlaceholder {
  color: #b2b9b3;
}

.submitBtn {
  margin-top: 34rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #15934d 0%, #0d7a3d 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 34rpx rgba(21, 147, 77, 0.18);
}

.submitBtn::after {
  display: none;
}

.backBtn {
  margin-top: 18rpx;
  background: transparent;
  color: #5d685e;
  font-size: 24rpx;
  font-weight: 700;
}

.backBtn::after {
  display: none;
}