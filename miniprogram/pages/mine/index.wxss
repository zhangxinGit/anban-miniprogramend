.page {
  min-height: 100vh;
  padding: 26rpx 24rpx 210rpx;
  background: #edf5ef;
  box-sizing: border-box;
}

.login {
  padding-top: 14rpx;
}

.loginHero {
  padding: 0 12rpx 0 8rpx;
}

.loginTitle {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.18;
  color: #30352f;
}

.loginSub {
  margin-top: 12rpx;
  max-width: 540rpx;
  font-size: 28rpx;
  line-height: 1.72;
  color: #5a665e;
}

.submitBtn {
  margin-top: 28rpx;
  margin-left: 0;
  margin-right: 0;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #15934d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.submitBtn.disabled {
  background: #c8ddd5 !important;
  color: rgba(255, 255, 255, 0.9) !important;
}

.submitBtn.disabled::after {
  display: none;
}

.submitBtn::after,
.wechatLink::after,
.profileLink::after,
.familyEditBtn::after,
.familyInviteBtn::after,
.contactBtn::after,
.settingsEntry::after {
  display: none;
}

.wechatLink {
  margin-top: 18rpx;
  margin-left: 0;
  margin-right: 0;
  width: 100%;
  padding: 0;
  background: transparent;
  color: #667269;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
}

.wechatLink[disabled] {
  color: rgba(0, 0, 0, 0.35);
}

.privacyRow {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.privacyCheckbox {
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  border-radius: 6rpx;
  border: 2rpx solid #c5c9c6;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  box-sizing: border-box;
}

.privacyCheckbox.checked {
  border-color: #15934d;
  background: #15934d;
}

.privacyCheckIcon {
  width: 20rpx;
  height: 12rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

.privacyText {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.65;
  color: #748077;
}

.privacyLink {
  color: #15934d;
  font-weight: 600;
}

.displaySwitchCard {
  width: 100%;
  padding: 16rpx 18rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 10rpx 22rpx rgba(15, 64, 35, 0.05);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.loginDisplaySwitchCard {
  margin-top: 28rpx;
}

.displaySwitchSummary {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.displaySwitchLabel {
  flex-shrink: 0;
  font-size: 28rpx;
  line-height: 1.35;
  color: #233026;
  font-weight: 800;
  white-space: nowrap;
}

.displaySwitchCurrent {
  min-width: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(21, 147, 77, 0.08);
  color: #15934d;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
  white-space: nowrap;
}

.displaySwitchActions {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: var(--ab-display-switch-gap);
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f2f6f2;
}

.displaySwitchOption {
  margin: 0;
  flex-shrink: 0;
  min-width: 112rpx;
  min-height: var(--ab-display-switch-height);
  padding: 0 var(--ab-display-switch-padding-x);
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #748077;
  font-size: var(--ab-display-switch-font-size);
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
  white-space: nowrap;
  border: 0;
}

.displaySwitchOption::after {
  display: none;
}

.displaySwitchOption.active {
  background: #15934d;
  color: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(21, 147, 77, 0.16);
}

.loginAdvisorCard {
  margin-top: 34rpx;
  width: 100%;
  padding: 16rpx 18rpx 16rpx 14rpx;
  background: #ffffff;
  border-radius: 14rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.06);
  box-shadow: 0 10rpx 22rpx rgba(15, 64, 35, 0.05);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.loginAdvisorImage {
  width: 204rpx;
  height: 128rpx;
  display: block;
  flex-shrink: 0;
}

.loginAdvisorMain {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding-right: 2rpx;
}

.loginAdvisorTitle {
  font-size: 29rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #2a3128;
}

.loginAdvisorAction {
  margin-top: 16rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 192rpx;
  min-height: 60rpx;
  padding: 0 16rpx 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffa94d 0%, #f28319 100%);
  box-shadow: 0 6rpx 12rpx rgba(242, 131, 25, 0.18);
  justify-content: center;
}

.loginAdvisorActionText {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.loginAdvisorActionIcon {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.loginAdvisorActionDot {
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: #ffffff;
  flex-shrink: 0;
}

.account {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.referralCard {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #FFF8ED 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(242, 131, 25, 0.14);
  box-shadow: 0 14rpx 30rpx rgba(130, 88, 21, 0.08);
}

.referralHead {
  display: flex;
  align-items: center;
}

.referralState,
.referralBoundBox,
.referralCodeBox {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
}

.referralState {
  font-size: 24rpx;
  line-height: 1.5;
  color: #6E6A60;
}

.referralBoundLabel,
.referralCodeLabel {
  font-size: 22rpx;
  line-height: 1.4;
  color: #8A7A5E;
}

.referralBoundValue,
.referralCodeValue {
  margin-top: 8rpx;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #2F342C;
}

.referralActions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.referralPrimaryBtn,
.referralGhostBtn,
.referralBindBtn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.referralPrimaryBtn::after,
.referralGhostBtn::after,
.referralBindBtn::after {
  display: none;
}

.referralPrimaryBtn {
  flex: 1;
  background: linear-gradient(135deg, #FFA94D 0%, #F28319 100%);
  color: #FFFFFF;
}

.referralGhostBtn {
  min-width: 188rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(242, 131, 25, 0.22);
  color: #B96810;
}

.referralPopup {
  padding-top: 54rpx;
}

.referralPopupTitle {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #2D312B;
  text-align: center;
}

.referralPopupQr {
  margin: 22rpx auto 0;
  width: 320rpx;
  height: 320rpx;
  display: block;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.referralPopupCodeLabel {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8A7A5E;
  text-align: center;
}

.referralPopupCodeValue {
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #2F342C;
  text-align: center;
  letter-spacing: 4rpx;
}

.profileHero {
  padding: 8rpx 6rpx 0;
}

.profileLeft {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.profileAvatarWrap {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 10rpx 24rpx rgba(15, 64, 35, 0.06);
  flex-shrink: 0;
}

.profileAvatarBtn {
  margin: 0;
  padding: 0;
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  flex-shrink: 0;
  line-height: 1;
}

.profileAvatarBtn::after {
  display: none;
}

.profileAvatar,
.profileAvatarFallback {
  width: 100%;
  height: 100%;
}

.profileAvatarFallback {
  background: #F5F5F5;
}

.profileMain {
  min-width: 0;
  flex: 1;
}

.profileName {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.18;
  color: #0f1812;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profileMetaRow {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  flex-wrap: wrap;
}

.profilePhone {
  font-size: 26rpx;
  color: #0f1812;
}

.profileLink {
  padding: 4rpx 8rpx;
  margin: 0;
  background: transparent;
  color: #15934d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
  flex-shrink: 0;
  white-space: nowrap;
  min-width: 0;
}

.page.display-mode-standard .profileMetaRow {
  flex-wrap: nowrap;
  align-items: center;
}

.page.display-mode-standard .profilePhone {
  flex-shrink: 0;
  line-height: 1.2;
}

.page.display-mode-standard .profileLink {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: auto;
  line-height: 1.2;
  white-space: nowrap;
}

.familyCard,
.contactCard,
.fallback .card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 64, 35, 0.06);
  border: 1rpx solid rgba(21, 147, 77, 0.08);
}

.familyCard {
  padding: 32rpx 28rpx 30rpx;
}

.familyCardHead {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
}

.familyTitle {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f1812;
}

.familyInfoRow {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.familyMembersMeta {
  margin-top: 28rpx;
}

.familyInfoIcon {
  width: 34rpx;
  height: 34rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  flex-shrink: 0;
  opacity: 0.65;
}

.icon-location {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><path fill='%23888888' d='M32 8c-10.5 0-19 8.2-19 18.3 0 13 15.8 27.8 18 30.8.6.6 1.4.9 2.2.9.8 0 1.6-.3 2.2-.9 2.2-3 18-17.8 18-30.8C51 16.2 42.5 8 32 8Zm0 25.2a6.9 6.9 0 1 1 0-13.8 6.9 6.9 0 0 1 0 13.8Z'/></svg>");
}

.icon-members {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><path fill='%23888888' d='M21 11a8 8 0 1 1 0 16 8 8 0 0 1 0-16Zm22 3a7 7 0 1 1 0 14 7 7 0 0 1 0-14ZM9 46.5C9 39.6 14.6 34 21.5 34h3C31.4 34 37 39.6 37 46.5V50H9v-3.5Zm30 3.5v-3c0-5.2 4.2-9.5 9.5-9.5h.5c3 0 5.7 1.4 7.5 3.6V50H39Z'/></svg>");
}

.familyInfoText {
  font-size: 24rpx;
  line-height: 1.6;
  color: #5b685f;
}

.familyMembersRow {
  margin-top: 30rpx;
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  gap: 16rpx;
  flex-wrap: wrap;
}

.memberCard {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 124rpx;
  gap: 10rpx;
}

.memberAvatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx solid rgba(21, 147, 77, 0.45);
  box-shadow: 0 10rpx 20rpx rgba(15, 64, 35, 0.08);
}

.memberAvatar.is-admin {
  border-color: #ff9a2b;
}

.memberAvatar.tone-1 {
  background: #f5f5f5;
}

.memberAvatar.tone-2 {
  background: #f5efe9;
}

.memberAvatar.tone-3 {
  background: #f4dce1;
}

.memberAvatar.tone-4 {
  background: #edf3ee;
}

.memberAvatarImg {
  width: 100%;
  height: 100%;
}

.memberAvatarText {
  font-size: 32rpx;
  font-weight: 900;
  color: rgba(0, 0, 0, 0.52);
}

.memberBadge {
  min-width: 86rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  text-align: center;
}

.memberBadge.is-admin {
  background: #ff9a2b;
  color: #ffffff;
}

.memberBadge.is-self,
.memberBadge.is-member {
  background: #d9f4dd;
  color: #15934d;
}

.familyInviteBtn {
  margin-top: 36rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 18rpx;
  background: #f5fbf6;
  border: 1rpx solid #b7e0c3;
  color: #15934d;
  font-size: 24rpx;
  font-weight: 800;
}

.serviceProcessCard {
  padding: 28rpx 26rpx;
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(15, 64, 35, 0.06);
}

.serviceProcessHead {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.serviceProcessTitleWrap {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.serviceProcessEyebrow {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  color: #15934d;
}

.serviceProcessTitle {
  font-size: 30rpx;
  line-height: 1.4;
  color: #1f2a20;
  font-weight: 700;
}

.serviceProcessStatus {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.serviceProcessStatus-pending {
  background: rgba(240, 138, 42, 0.12);
  color: #f08a2a;
}

.serviceProcessStatus-completed {
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
}

.serviceProcessStatus-cancelled {
  background: rgba(208, 98, 52, 0.12);
  color: #d06234;
}

.serviceProcessMeta,
.serviceProcessHint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #5b685f;
}

.serviceProcessActions {
  margin-top: 22rpx;
  display: flex;
  gap: 14rpx;
}

.serviceProcessActionBtn {
  margin: 0;
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.serviceProcessActionBtn::after {
  display: none;
}

.serviceProcessActionBtn-secondary {
  background: #f5fbf6;
  color: #0e8946;
  border: 1rpx solid rgba(14, 137, 70, 0.16);
}

.serviceProcessActionBtn-primary {
  background: #0e8946;
  color: #ffffff;
  border: 1rpx solid #0e8946;
  box-shadow: 0 10rpx 18rpx rgba(14, 137, 70, 0.14);
}

.invitePopupMask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.42);
  box-sizing: border-box;
}

.invitePopup {
  width: 100%;
  max-width: 622rpx;
  padding: 34rpx 0 0;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.16);
  overflow: hidden;
  position: relative;
}

.invitePopupClose {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  color: #a7a7a7;
  font-size: 42rpx;
  font-weight: 300;
}

.invitePopupClose::after {
  display: none;
}

.invitePopupIcon {
  width: 94rpx;
  height: 94rpx;
  margin: 0 auto;
  background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><g fill='%2315934d'><circle cx='22' cy='16' r='8'/><path d='M10 44c0-8 6-14 14-14s14 6 14 14v6H10z'/><path d='M41 22l12 0-4-4 2-2 8 8-8 8-2-2 4-4H41z'/></g></svg>") center/contain no-repeat;
}

.invitePopupTitle {
  margin-top: 18rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #0f1812;
}

.invitePopupExpire {
  margin-top: 16rpx;
  text-align: center;
  color: #4f5b51;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
}

.invitePopupDesc {
  margin: 12rpx 48rpx 0;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.6;
  color: #666666;
}

.invitePopupActions {
  margin-top: 28rpx;
  display: flex;
  gap: 0;
  border-top: 1rpx solid #e8e8e8;
}

.invitePopupGhost,
.invitePopupPrimary {
  flex: 1;
  margin: 0;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 0;
  font-size: 28rpx;
  font-weight: 700;
}

.invitePopupGhost::after,
.invitePopupPrimary::after {
  display: none;
}

.invitePopupGhost {
  background: #FFFFFF;
  color: #666666;
  border: 0;
  border-right: 1rpx solid #e8e8e8;
}

.invitePopupPrimary {
  background: #ffffff;
  color: #15934d;
  border: 0;
}

.invitePopupPrimary[disabled] {
  background: #ffffff;
  color: rgba(21, 147, 77, 0.35);
}

.familyState {
  margin-top: 24rpx;
  padding: 18rpx 0 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(0, 0, 0, 0.52);
}

/* 适老好物订单 */
.suitableOrdersCard {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 64, 35, 0.06);
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  margin-top: 26rpx;
}

.suitableOrdersHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.suitableOrdersTitle {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f1812;
}

.suitableOrdersMore {
  font-size: 24rpx;
  color: #15934d;
  font-weight: 700;
  padding: 4rpx 12rpx;
}

.suitableOrdersState {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.52);
  padding: 18rpx 0 10rpx;
  line-height: 1.6;
}

.suitableOrderItem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.suitableOrderItem:last-child {
  border-bottom: none;
}

.suitableOrderInfo {
  flex: 1;
  min-width: 0;
}

.suitableOrderName {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.suitableOrderMeta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.suitableOrderTime {
  font-size: 22rpx;
  color: #999;
}

.suitableOrderStatus {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.suitableOrderStatus.status-pending {
  background: rgba(240, 138, 42, 0.12);
  color: #f08a2a;
}

.suitableOrderStatus.status-processing {
  background: rgba(33, 150, 243, 0.12);
  color: #2196f3;
}

.suitableOrderStatus.status-delivering {
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
}

.suitableOrderStatus.status-completed {
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
}

.suitableOrderStatus.status-cancelled {
  background: rgba(208, 98, 52, 0.12);
  color: #d06234;
}

.suitableOrderStatus.status-unknown {
  background: rgba(158, 158, 158, 0.12);
  color: #757575;
}

.suitableOrderAmount {
  font-size: 32rpx;
  font-weight: 800;
  color: #FF6B35;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.contactCard {
  padding: 0;
  overflow: hidden;
}

.contactCardImage {
  width: 100%;
  display: block;
}

.staffEntryCard {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  text-align: left;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(21, 147, 77, 0.1) 0%, rgba(255, 255, 255, 0.98) 100%);
  border: 1rpx solid rgba(21, 147, 77, 0.12);
  box-shadow: 0 14rpx 34rpx rgba(15, 64, 35, 0.06);
}

.staffEntryCard::after {
  display: none;
}

.staffEntryMain {
  min-width: 0;
  flex: 1;
}

.staffEntryTitle {
  font-size: 30rpx;
  line-height: 1.35;
  color: #17311f;
  font-weight: 900;
}

.staffEntrySub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(23, 49, 31, 0.66);
}

.staffEntryArrow {
  flex-shrink: 0;
  min-width: 116rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #15934d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
  writing-mode: horizontal-tb;
}

.logoutCard {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(15, 64, 35, 0.06);
}

.accountLogoutBtn {
  margin: 0;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fcfcfb 0%, #f6f6f3 100%);
  border: 1rpx solid #f0f0ec;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  color: #8f8f8f;
  font-size: 30rpx;
  font-weight: 800;
}

.accountLogoutBtn::after {
  display: none;
}

.logoutTip {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f9791;
}

.fallback {
  padding-top: 12rpx;
}

.card {
  padding: 32rpx 24rpx;
}

.acTitle {
  font-size: var(--ab-font-size-lg);
  font-weight: 800;
  color: var(--ab-color-primary);
}

.acTip {
  margin-top: 14rpx;
  font-size: var(--ab-font-size-min);
  line-height: var(--ab-line-height-base);
  color: var(--ab-color-text-2);
}

/* ---- 未勾选协议时，次按钮禁用态样式 ---- */
.wechatLink.linkDisabled {
  background: rgba(0, 0, 0, 0.06) !important;
  color: rgba(0, 0, 0, 0.28) !important;
}

.wechatLink.linkDisabled::after {
  display: none;
}

/* ---- 文档全屏浮层（隐私政策 / 用户协议） ---- */
.docOverlayMask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.4);
}

.docOverlay {
  width: 100%;
  height: 100vh;
  background: #ffffff;
}

.docOverlayHeader {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 24rpx 36rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.docOverlayCloseBtn {
  position: absolute;
  left: 20rpx;
  top: 18rpx;
  width: 72rpx;
  height: 72rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 80rpx;
  color: #999999;
  border-radius: 50%;
}

.docOverlayTitle {
  font-size: 34rpx;
  font-weight: 800;
  color: #1a1a1a;
  text-align: center;
}

.docOverlayMeta {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  margin-top: 8rpx;
}

.docOverlayBody {
  padding: 30rpx 36rpx 24rpx;
}

.docSection {
  margin-bottom: 32rpx;
}

.docH2 {
  font-size: 29rpx;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  letter-spacing: 0.4rpx;
}

.docP {
  font-size: 26rpx;
  line-height: 1.85;
  color: #333333;
  margin-bottom: 18rpx;
  text-align: justify;
}

.docList {
  margin-left: 10rpx;
  margin-bottom: 18rpx;
}

.docLi {
  font-size: 26rpx;
  line-height: 1.85;
  color: #333333;
  margin-bottom: 10rpx;
  padding-left: 12rpx;
}

.docStrong {
  font-weight: 700;
  color: #1a1a1a;
}

.docOverlayFooter {
  padding: 10rpx 36rpx calc(24rpx + env(safe-area-inset-bottom));
}

.docOverlayConfirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #15934d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
}

.docOverlayConfirm::after {
  display: none;
}

/* ========== 评估强提醒弹窗 ========== */

.assessOverlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.assessPopup {
  width: 620rpx;
  background: #F5F8E9;
  border-radius: 36rpx;
  padding: 48rpx 40rpx 52rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}

.assessIllustration {
  width: 500rpx;
  height: 380rpx;
  border-radius: 24rpx;
  margin-bottom: -48rpx;
  position: relative;
  z-index: 1;
}

.assessCard {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.assessCardTitle {
  font-size: 38rpx;
  font-weight: 800;
  color: #15934D;
  text-align: center;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

.assessDivider {
  width: 100%;
  height: 2rpx;
  background: #D4E5C7;
  margin: 22rpx 0;
  opacity: 0.6;
}

.assessCardBody {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.assessCardText {
  font-size: 30rpx;
  color: #444444;
  text-align: center;
  line-height: 1.7;
  padding: 0 8rpx;
}

.assessPrimaryBtn {
  width: 100%;
  height: 96rpx;
  margin-top: 32rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #3EA24F, #2E8B47);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 96rpx;
  text-align: center;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 71, 0.3);
  letter-spacing: 2rpx;
}

.assessPrimaryBtn::after {
  display: none;
}

.assessLaterLink {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #8C9196;
  text-align: center;
  line-height: 1;
  padding: 12rpx 24rpx;
  letter-spacing: 1rpx;
}

.assessCloseBtn {
  margin-top: 36rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.assessCloseIcon {
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
}
