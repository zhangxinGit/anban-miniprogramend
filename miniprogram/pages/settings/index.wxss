.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8f5;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx 28rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(15, 64, 35, 0.05);
}

.actionCard {
  margin-top: 24rpx;
}

.displayCard {
  margin-top: 24rpx;
}

.sectionTitle {
  font-size: 30rpx;
  line-height: 1.3;
  color: #1f2a20;
  font-weight: 800;
}

.settingRow {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.settingLabel {
  font-size: 26rpx;
  color: #6f776f;
}

.settingValue {
  font-size: 28rpx;
  color: #1f2a20;
  font-weight: 700;
}

.displaySwitchBar {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f9fbf8 0%, #f2f7f3 100%);
  border: 1rpx solid rgba(21, 147, 77, 0.08);
}

.displaySwitchSummary {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.displaySwitchLabel {
  flex-shrink: 0;
  font-size: 28rpx;
  line-height: 1.35;
  color: #1f2a20;
  font-weight: 800;
  white-space: nowrap;
}

.displaySwitchCurrent {
  min-width: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(21, 147, 77, 0.08);
  color: #15934d;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
  white-space: nowrap;
}

.displaySwitchActions {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: var(--ab-display-switch-gap);
  padding: 8rpx;
  border-radius: 999rpx;
  background: #eef4ef;
}

.displaySwitchOption {
  margin: 0;
  flex-shrink: 0;
  min-width: 112rpx;
  min-height: var(--ab-display-switch-height);
  padding: 0 var(--ab-display-switch-padding-x);
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #70806f;
  font-size: var(--ab-display-switch-font-size);
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
  white-space: nowrap;
  border: 0;
}

.displaySwitchOption::after {
  display: none;
}

.displaySwitchOption.active {
  background: #15934d;
  color: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(21, 147, 77, 0.16);
}

.logoutBtn {
  margin: 0;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #15934d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.logoutBtn::after {
  display: none;
}

.tips {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8f9791;
}