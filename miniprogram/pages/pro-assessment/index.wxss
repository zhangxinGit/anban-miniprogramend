.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8f5;
  box-sizing: border-box;
}

.fadeIn {
  animation: fadeIn 240ms ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.content {
  padding-top: 12rpx;
}

.formCard {
  padding: 24rpx 22rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(15, 64, 35, 0.05);
}

.sheetTitle {
  font-size: 30rpx;
  line-height: 1.3;
  color: #1f2a20;
  font-weight: 800;
}

.sheetDesc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #979e98;
}

.serviceRow {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #f7faf7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.serviceLabel {
  font-size: 22rpx;
  color: #8e978f;
}

.serviceValue {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  color: #1f2a20;
  font-weight: 600;
}

.statusBanner {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #f3faf5;
  border: 1rpx solid #d9eedf;
  color: #15934d;
  font-size: 22rpx;
  line-height: 1.6;
  font-weight: 600;
}

.statusBanner.isWarning {
  background: #fff7ef;
  border-color: #f2dcc2;
  color: #c57c37;
}

.formList {
  margin-top: 18rpx;
}

.field {
  min-height: 92rpx;
  padding: 0 2rpx;
  border-bottom: 1rpx solid #f0f2ef;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.fieldColumn {
  display: block;
  min-height: 0;
  padding-top: 20rpx;
}

.k {
  width: 130rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #6c726d;
  font-weight: 500;
}

.kBlock {
  display: block;
  width: auto;
}

.input,
.fieldValue {
  flex: 1;
  min-width: 0;
  min-height: 48rpx;
  font-size: 24rpx;
  line-height: 48rpx;
  color: #1f2a20;
  text-align: right;
  font-weight: 500;
}

.fieldValue.placeholder {
  color: #9aa19b;
}

.pickerTrigger {
  flex: 1;
  min-width: 0;
}

.inputLong {
  font-size: 22rpx;
}

.noBorder {
  border-bottom: 0;
}

.textarea {
  width: 100%;
  margin-top: 18rpx;
  min-height: 274rpx;
  padding: 24rpx 22rpx;
  border-radius: 16rpx;
  background: #f6f7f6;
  border: 0;
  box-sizing: border-box;
  font-size: 24rpx;
  line-height: 1.7;
  color: #1f2a20;
}

.inputPlaceholder {
  color: #b0b5b0;
}

.submitBtn,
.cancelBtn,
.retryBtn,
.successPrimary,
.successClose {
  margin: 0;
}

.submitBtn,
.retryBtn,
.successPrimary {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #169247;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.submitBtn {
  margin-top: 26rpx;
}

.cancelBtn {
  margin-top: 16rpx;
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #7d857f;
  border: 1rpx solid #e7ebe7;
  font-size: 24rpx;
  font-weight: 700;
}

.submitBtn::after,
.cancelBtn::after,
.retryBtn::after,
.successPrimary::after,
.successClose::after {
  display: none;
}

.state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(21, 147, 77, 0.12);
  border-top-color: #15934d;
  animation: spin 800ms linear infinite;
}

@keyframes spin {
  from { transform: rotate(0); }
  to { transform: rotate(360deg); }
}

.successMask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(12, 28, 18, 0.46);
}

.successDialog {
  width: 100%;
  max-width: 460rpx;
  padding: 36rpx 28rpx 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
  box-sizing: border-box;
  position: relative;
}

.successIcon {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
  background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><g fill='none' stroke='%2315934d' stroke-linecap='round' stroke-linejoin='round' stroke-width='3.5'><path d='M18 8v8'/><path d='M46 8v8'/><rect x='12' y='14' width='32' height='34' rx='4'/><path d='M12 24h32'/><path d='M22 32h8'/><path d='M22 40h12'/><path d='m40 42 5 5 9-11'/></g></svg>") center/contain no-repeat;
}

.successClose {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  background: transparent;
  color: #adb3ae;
  font-size: 40rpx;
  font-weight: 300;
}

.successTitle {
  margin-top: 16rpx;
  text-align: center;
  font-size: 34rpx;
  color: #1f2a20;
  font-weight: 800;
}

.successText,
.successTime,
.stateText {
  text-align: center;
}

.successText {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667069;
}

.successTime {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #15934d;
  font-weight: 700;
}

.successPrimary {
  margin-top: 24rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 16rpx;
  background: #15934d;
  border: 1rpx solid #15934d;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}
