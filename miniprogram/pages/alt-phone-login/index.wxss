.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 120rpx;
  background: #f7f8f5;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  width: 100%;
  padding: 0 20rpx 26rpx;
}
.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2a20;
  text-align: left;
  padding-left: 8rpx;
}
.sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #8b968d;
  text-align: left;
  padding-left: 8rpx;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 64, 35, 0.05);
  border: 1rpx solid rgba(21, 147, 77, 0.08);
}

.field {
  min-height: 118rpx;
  padding: 16rpx 8rpx 12rpx;
  border-bottom: 1rpx solid #edf1ec;
  box-sizing: border-box;
}
.field:last-of-type {
  border-bottom: 0;
}
.fieldLabel {
  display: block;
  font-size: 26rpx;
  color: #8f9791;
  font-weight: 600;
  margin-bottom: 26rpx;
}
.fieldInput {
  min-height: 48rpx;
  font-size: 30rpx;
  color: #1f2a20;
  line-height: 48rpx;
}

.fieldPlaceholder {
  color: #b2b9b3;
}
.fieldRow {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.fieldGrow {
  flex: 1;
  min-width: 0;
}

.codeBtn {
  flex-shrink: 0;
  min-width: 180rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #15934d;
  background: #f3f7f4;
  border: 1rpx solid #cfe9d7;
  border-radius: 16rpx;
  margin: 0;
  font-weight: 700;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.codeBtn--disabled {
  color: rgba(21, 147, 77, 0.42) !important;
  background: #eff5f0 !important;
  border-color: #e1e7e2 !important;
  pointer-events: none;
}

.submitBtn {
  margin-top: 34rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 16rpx;
  background: #15934d;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 0;
  box-shadow: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.submitBtn::after { display: none; }

.backLink {
  margin-top: 18rpx;
  padding: 18rpx 0;
  background: transparent;
  color: #5f6660;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  width: 100%;
}
.backLink::after { display: none; }
.backLink[disabled] { color: rgba(0, 0, 0, 0.35); }

