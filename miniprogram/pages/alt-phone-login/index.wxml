<view class="page {{displayModeClass}}">
  <view class="header">
    <view class="title">使用其他手机号</view>
    <view class="sub">请输入手机号并完成验证码验证</view>
  </view>

  <view class="card">
    <view class="field">
      <text class="fieldLabel">手机号</text>
      <input
        class="fieldInput"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        placeholder-class="fieldPlaceholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="field fieldRow">
      <view class="fieldGrow">
        <text class="fieldLabel">验证码</text>
        <input
          class="fieldInput"
          type="number"
          maxlength="6"
          placeholder="6位数字"
          placeholder-class="fieldPlaceholder"
          value="{{code}}"
          bindinput="onCodeInput"
        />
      </view>
      <view class="codeBtn {{codeSeconds > 0 || loginLoading ? 'codeBtn--disabled' : ''}}" bindtap="onSendCode">
        {{codeSeconds > 0 ? '重新获取' + codeSeconds + 's' : '获取验证码'}}
      </view>
    </view>
  </view>

  <button
    class="submitBtn"
    loading="{{loginLoading}}"
    disabled="{{loginLoading}}"
    bindtap="onLogin"
  >
    登录
  </button>

  <button class="backLink" disabled="{{loginLoading}}" bindtap="onBack">
    返回
  </button>
</view>

