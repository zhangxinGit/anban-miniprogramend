.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 250rpx;
  background: #f7f8f5;
  box-sizing: border-box;
}

.fadeIn {
  animation: fadeIn 240ms ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.heroCard {
  padding: 34rpx 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(15, 64, 35, 0.05);
}

.heroTag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
  font-size: 22rpx;
  font-weight: 700;
}

.heroTitle {
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #1f2a20;
}

.heroSub {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8a7d;
}

.sceneCard,
.statusCard,
.formCard,
.tipsCard {
  margin-top: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(15, 64, 35, 0.05);
}

.sceneLabel,
.tipsTitle {
  font-size: 22rpx;
  color: #7b8a7d;
  font-weight: 600;
}

.sceneValue,
.statusTitle,
.sectionTitle {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.36;
  color: #1f2a20;
  font-weight: 700;
}

.sceneHint,
.statusSub,
.tipsText,
.assistText,
.submitMetaText,
.stateText,
.advisorText {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.68;
  color: #7b8a7d;
}

.statusCard {
  position: relative;
}

.statusPill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
  font-size: 22rpx;
  font-weight: 700;
}

.statusPill.warning {
  background: rgba(240, 138, 42, 0.12);
  color: #f08a2a;
}

.statusText {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #15934d;
  font-weight: 700;
}

.statusCard.isCancelled .statusText,
.statusCard.isCancelled .statusTitle {
  color: #1f2a20;
}

.sectionHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.sectionBadge {
  flex-shrink: 0;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
  font-size: 20rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.form {
  margin-top: 12rpx;
}

.field {
  min-height: 92rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf1ec;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.fieldColumn {
  display: block;
  min-height: 0;
}

.k {
  width: 150rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #1f2a20;
  font-weight: 600;
}

.input,
.fieldValue {
  flex: 1;
  min-width: 0;
  min-height: 48rpx;
  font-size: 28rpx;
  line-height: 48rpx;
  color: #1f2a20;
  text-align: right;
}

.fieldValue.placeholder {
  color: #a1aa9d;
}

.pickerTrigger,
.detailInputWrap {
  flex: 1;
  min-width: 0;
}

.detailInput {
  width: 100%;
}

.fieldArrow {
  flex-shrink: 0;
  font-size: 34rpx;
  line-height: 1;
  color: #b5beb2;
}

.textarea {
  width: 100%;
  margin-top: 18rpx;
  min-height: 220rpx;
  padding: 22rpx 20rpx;
  border-radius: 16rpx;
  background: #f7faf7;
  border: 1rpx solid #edf1ec;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.7;
  color: #1f2a20;
}

.inputPlaceholder {
  color: #a1aa9d;
}

.assistText {
  padding-top: 20rpx;
}

.dockSpacer {
  height: 16rpx;
}

.submitDock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 -12rpx 36rpx rgba(15, 64, 35, 0.08);
}

.safe-area {
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.submitMetaTitle {
  font-size: 24rpx;
  color: #1f2a20;
  font-weight: 700;
}

.dockPrimary,
.dockDanger,
.retryBtn,
.successPrimary,
.successGhost {
  margin: 0;
}

.dockPrimary,
.retryBtn,
.successPrimary {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 16rpx;
  background: #15934d;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.dockDanger {
  margin-top: 12rpx;
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #d06234;
  border: 1rpx solid rgba(240, 138, 42, 0.35);
  font-size: 28rpx;
  font-weight: 700;
}

.retryBtn,
.successPrimary {
  margin-top: 18rpx;
}

.dockPrimary::after,
.dockDanger::after,
.retryBtn::after,
.successPrimary::after,
.successGhost::after {
  display: none;
}

.state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(21, 147, 77, 0.12);
  border-top-color: #15934d;
  animation: spin 800ms linear infinite;
}

@keyframes spin {
  from { transform: rotate(0); }
  to { transform: rotate(360deg); }
}

.successMask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(12, 28, 18, 0.46);
}

.successDialog {
  width: 100%;
  padding: 40rpx 32rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
  box-sizing: border-box;
  position: relative;
}

.successCloseBtn {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: #999;
  background: transparent;
  border: none;
  margin: 0;
  padding: 0;
}

.successCloseBtn::after {
  display: none;
}

.successIcon {
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf8f1;
  border: 1rpx solid #dcefe2;
  box-shadow: none;
}

.successCheck {
  font-size: 56rpx;
  line-height: 1;
  color: #15934d;
  font-weight: 800;
}

.successTitle {
  margin-top: 24rpx;
  text-align: center;
  font-size: 36rpx;
  color: #1f2a20;
  font-weight: 800;
}

.successText,
.successTime {
  text-align: center;
}

.successTime {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #15934d;
  font-weight: 700;
}

.successGhost {
  margin-top: 12rpx;
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  background: #f5f7f4;
  color: #4e5e52;
  font-size: 26rpx;
  font-weight: 700;
}

