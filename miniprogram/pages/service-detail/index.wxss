.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 194rpx;
  background: linear-gradient(180deg, #eff8f1 0, #f7f8f4 180rpx, #f7f8f4 100%);
  box-sizing: border-box;
}

.heroCard {
  width: 100%;
  height: 430rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background: #f1f4ef;
  box-shadow: 0 18rpx 42rpx rgba(15, 64, 35, 0.12);
}

.heroImg,
.heroFallback {
  width: 100%;
  height: 100%;
}

.heroFallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #7b8a7d;
}

.detailCard,
.promiseCard,
.bookingCard {
  margin-top: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 30rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(15, 64, 35, 0.06);
}

.detailCard {
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.detailPriceRow {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex-wrap: wrap;
}

.detailPriceSymbol {
  font-size: 30rpx;
  color: #15934d;
  font-weight: 700;
}

.detailPrice {
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1;
  color: #15934d;
}

.detailOriginalPrice {
  font-size: 24rpx;
  color: #9ca79d;
  text-decoration: line-through;
}

.detailBadge {
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(240, 138, 42, 0.12);
  color: #f08a2a;
  font-size: 20rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.detailTitle {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.45;
  color: #1f2a20;
  font-weight: 700;
}

.detailMetaRow {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detailMeta,
.detailSales,
.bookingCardMeta,
.bookingCardHint,
.bookingCardTime,
.bookingCardFootnote,
.promiseText,
.successText,
.advisorText,
.stateText,
.contactText {
  font-size: 22rpx;
  line-height: 1.65;
  color: #7b8a7d;
}

.detailSales {
  color: #f08a2a;
  font-weight: 700;
}

.detailTags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detailTag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f6faf7;
  border: 1rpx solid #e3ece4;
  font-size: 20rpx;
  line-height: 1.4;
  color: #5c6b60;
}

.promiseCard {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.promiseRow {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.promiseDot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #15934d;
  flex-shrink: 0;
}

.bookingCardHead {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.bookingCardTitleWrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bookingCardEyebrow {
  font-size: 20rpx;
  color: #7b8a7d;
  font-weight: 700;
}

.bookingCardTitle,
.advisorTitle,
.successTitle {
  font-size: 30rpx;
  line-height: 1.4;
  color: #1f2a20;
  font-weight: 700;
}

.bookingCardStatus {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.bookingCardStatus-pending {
  background: rgba(240, 138, 42, 0.12);
  color: #f08a2a;
}

.bookingCardStatus-completed {
  background: rgba(21, 147, 77, 0.12);
  color: #15934d;
}

.bookingCardStatus-cancelled {
  background: rgba(208, 98, 52, 0.12);
  color: #d06234;
}

.bookingCardMeta,
.bookingCardHint,
.bookingCardTime {
  display: block;
  margin-top: 10rpx;
}

.bookingCardActions {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
}

.bookingGhostBtn {
  margin: 0;
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #1f2a20;
  font-size: 24rpx;
  font-weight: 700;
  border: 1rpx solid #e3ece4;
}

.bookingGhostBtn.isStrong {
  background: #f5f8f5;
}

.bookingGhostBtn::after {
  display: none;
}

.bookingCardFootnote {
  display: block;
  margin-top: 14rpx;
}

.bottomSpacer {
  height: 10rpx;
}

.bottomBar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 14rpx 18rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 -12rpx 36rpx rgba(15, 64, 35, 0.08);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.safe-area {
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
}

.contactBtn,
.bookBtn,
.successPrimary,
.successGhost {
  margin: 0;
}

.contactBtn {
  width: 120rpx;
  background: transparent;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.contactBtn::after,
.bookBtn::after,
.successPrimary::after,
.successGhost::after {
  display: none;
}

.contactCircle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f6faf7;
}

.contactIcon {
  width: 34rpx;
  height: 34rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.contactIcon.phone {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><path fill='%23f08a2a' d='M24.7 14.4c1.3-1.3 1.3-3.5 0-4.8l-4-4a3.4 3.4 0 0 0-4.8 0L9 12.5c-1.8 1.8-2.5 4.5-1.8 7 2.7 10.3 10 23 19.1 32.1s21.8 16.4 32.1 19.1c2.5.7 5.2 0 7-1.8l6.9-6.9a3.4 3.4 0 0 0 0-4.8l-4-4a3.4 3.4 0 0 0-4.8 0l-5 5c-1.2 1.2-3 1.6-4.6 1-4.8-1.7-10.4-5.4-15.1-10.1S30.4 38.9 28.7 34c-.6-1.6-.2-3.4 1-4.6l5-5Z'/></svg>");
}

.contactIcon.wechat {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><path fill='%2315934d' d='M24.6 12C14.3 12 6 19.5 6 28.8c0 5.4 2.8 10.1 7.2 13.2L11 50l8.3-4.1c1.7.5 3.5.8 5.3.8 10.3 0 18.6-7.5 18.6-16.8S34.9 12 24.6 12Zm22.5 15.3c-7 0-12.7 5.1-12.7 11.4 0 6.3 5.7 11.4 12.7 11.4 1.3 0 2.6-.2 3.8-.6L58 53l-1.9-5.7c2.3-2 3.7-4.9 3.7-8 0-6.3-5.7-11.4-12.7-11.4Z'/></svg>");
}

.bookBtn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #28c56e 0%, #15934d 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.spinner {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(21, 147, 77, 0.12);
  border-top-color: #15934d;
  animation: spin 800ms linear infinite;
}

.successMask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(12, 28, 18, 0.46);
}

.successDialog {
  width: 100%;
  padding: 40rpx 32rpx 32rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.18);
  box-sizing: border-box;
}

.successIcon {
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4ad580 0%, #15934d 100%);
  box-shadow: 0 16rpx 32rpx rgba(21, 147, 77, 0.24);
}

.successCheck {
  font-size: 56rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 800;
}

.successTitle {
  margin-top: 24rpx;
  text-align: center;
}

.successText {
  margin-top: 12rpx;
  text-align: center;
}

.advisorCard {
  margin-top: 28rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: #f6faf7;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.advisorImage {
  width: 116rpx;
  height: 116rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.advisorMeta {
  flex: 1;
  min-width: 0;
}

.successPrimary {
  margin-top: 22rpx;
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #28c56e 0%, #15934d 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.successGhost {
  margin-top: 12rpx;
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  background: #f5f7f4;
  color: #4e5e52;
  font-size: 26rpx;
  font-weight: 700;
}

@keyframes spin {
  from { transform: rotate(0); }
  to { transform: rotate(360deg); }
}