.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 24rpx 120rpx;
  background:
    linear-gradient(180deg, rgba(224, 244, 231, 0.92) 0%, rgba(245, 250, 246, 0.96) 34%, #f4f7f3 100%),
    radial-gradient(circle at top left, rgba(21, 147, 77, 0.12), rgba(21, 147, 77, 0) 38%);
}

.hero {
  padding: 8rpx 6rpx 26rpx;
}

.heroMeta {
  font-size: 22rpx;
  line-height: 1;
  color: #15934d;
  font-weight: 800;
}

.heroTitle {
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.2;
  color: #122616;
  font-weight: 900;
}

.heroSub {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5f6b61;
}

.panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.actionCard {
  margin: 0;
  text-align: left;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(21, 147, 77, 0.1);
  box-shadow: 0 18rpx 38rpx rgba(15, 64, 35, 0.07);
}

.actionCard::after {
  display: none;
}

.actionPrimary {
  background: linear-gradient(135deg, #15934d 0%, #0c6f38 100%);
  border-color: transparent;
  box-shadow: 0 18rpx 38rpx rgba(21, 147, 77, 0.18);
}

.actionTitle {
  font-size: 32rpx;
  line-height: 1.35;
  color: #142418;
  font-weight: 900;
}

.actionPrimary .actionTitle {
  color: #ffffff;
}

.actionDesc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #617063;
}

.actionPrimary .actionDesc {
  color: rgba(255, 255, 255, 0.88);
}

.tipsCard {
  margin-top: 28rpx;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(21, 147, 77, 0.08);
}

.tipsTitle {
  font-size: 28rpx;
  line-height: 1.4;
  color: #1f2a20;
  font-weight: 800;
}

.tipsText {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #647165;
}

.logoutBtn {
  margin-top: 36rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #ffffff;
  color: #d34f35;
  border: 1rpx solid rgba(211, 79, 53, 0.16);
  font-size: 30rpx;
  font-weight: 800;
}

.logoutBtn::after {
  display: none;
}

.logoutMask {
  position: fixed;
  inset: 0;
  z-index: 99;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.logoutDialog {
  width: 100%;
  max-width: 600rpx;
  padding: 40rpx 32rpx 36rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.2);
}

.logoutDialogTitle {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
  color: #1a1a1a;
  text-align: center;
}

.logoutDialogContent {
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #666666;
  text-align: left;
}

.logoutDialogActions {
  margin-top: 40rpx;
  display: flex;
  gap: 20rpx;
}

.logoutDialogBtn {
  flex: 1;
  margin: 0;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.logoutDialogBtn::after {
  display: none;
}

.logoutDialogCancel {
  background: #f5f5f5;
  color: #666666;
  border: none;
}

.logoutDialogConfirm {
  background: #15934d;
  color: #ffffff;
  border: none;
}