/* ============ SOS 求助结果覆盖层 ============ */
.sosResultOverlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
  padding: 32rpx;
  animation: sosOverlayFadeIn 0.3s ease;
}

@keyframes sosOverlayFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.sosResultCard {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  animation: sosCardSlideUp 0.35s ease;
}

@keyframes sosCardSlideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 顶部绿色成功条 */
.sosResultTopBar {
  background: linear-gradient(135deg, #0E8946 0%, #0ba360 100%);
  padding: 36rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.sosResultCheckmark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
  animation: sosCheckPop 0.4s ease 0.15s both;
}

@keyframes sosCheckPop {
  0%   { transform: scale(0); opacity: 0; }
  60%  { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.sosResultTopTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.4;
}

/* 核心话术 */
.sosResultNotice {
  padding: 28rpx 32rpx 20rpx;
}

.sosResultNoticeText {
  font-size: 28rpx;
  line-height: 1.7;
  color: #333;
}

/* 工单信息卡片 */
.sosTicketCard {
  margin: 0 32rpx 20rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.sosTicketRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #E8ECF0;
