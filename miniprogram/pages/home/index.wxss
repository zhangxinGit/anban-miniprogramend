.sosFloatButton {
  position: fixed;
  right: 24rpx;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 1001;
  width: 176rpx;
  min-height: 126rpx;
  padding: 46rpx 0 18rpx;
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: linear-gradient(135deg, #e35a4a 0%, #be312f 100%);
  color: #ffffff;
  box-shadow: 0 26rpx 52rpx rgba(183, 58, 52, 0.3);
  overflow: visible;
}

.sosLamp {
  position: absolute;
  left: 50%;
  top: -54rpx;
  width: 112rpx;
  height: 112rpx;
  transform: translateX(-50%);
  pointer-events: none;
}

.sosLampGlow {
  position: absolute;
  inset: 4rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 247, 195, 0.98) 0%, rgba(255, 226, 114, 0.58) 38%, rgba(255, 185, 44, 0.18) 58%, rgba(255, 205, 74, 0) 82%);
  transform-origin: center;
  animation: sosLampPulse 1400ms ease-in-out infinite;
}

.sosLampBulb {
  position: absolute;
  left: 50%;
  top: 16rpx;
  width: 68rpx;
  height: 58rpx;
  transform: translateX(-50%);
  border-radius: 44rpx 44rpx 20rpx 20rpx;
  background: radial-gradient(circle at 34% 24%, #fffef2 0%, #fff1a6 22%, #ffd953 58%, #f3a51f 100%);
  border: 2rpx solid rgba(255, 248, 205, 0.82);
  box-sizing: border-box;
  box-shadow: 0 14rpx 32rpx rgba(255, 188, 35, 0.52), inset 0 -6rpx 10rpx rgba(196, 110, 9, 0.16);
  animation: sosLampFlash 900ms ease-in-out infinite;
}

.sosLampFilament {
  position: absolute;
  left: 50%;
  top: 22rpx;
  width: 20rpx;
  height: 18rpx;
  transform: translateX(-50%);
  border: 3rpx solid rgba(132, 87, 18, 0.78);
  border-top: 0;
  border-radius: 0 0 10rpx 10rpx;
  box-sizing: border-box;
}

.sosLampNeck {
  position: absolute;
  left: 50%;
  bottom: 22rpx;
  width: 20rpx;
  height: 14rpx;
  transform: translateX(-50%);
  border-radius: 8rpx;
  background: linear-gradient(180deg, #d9a13e 0%, #a96c17 100%);
}

.sosLampBase {
  position: absolute;
  left: 50%;
  bottom: 6rpx;
  width: 36rpx;
  height: 20rpx;
  transform: translateX(-50%);
  border-radius: 12rpx;
  background: linear-gradient(180deg, #b07522 0%, #71430f 100%);
  box-shadow: 0 8rpx 14rpx rgba(92, 58, 14, 0.24);
}

.sosFloatTitle {
  margin-top: 6rpx;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 800;
}

@keyframes sosLampPulse {
  0%,
  100% {
    opacity: 0.56;
    transform: scale(0.88);
  }

  35% {
    opacity: 1;
    transform: scale(1.08);
  }

  65% {
    opacity: 0.74;
    transform: scale(0.96);
  }
}

@keyframes sosLampFlash {
  0%,
  100% {
    transform: translateX(-50%) translateY(0) scale(0.98);
    box-shadow: 0 12rpx 24rpx rgba(255, 188, 35, 0.36), 0 0 0 0 rgba(255, 222, 109, 0), inset 0 -6rpx 10rpx rgba(196, 110, 9, 0.16);
  }

  28% {
    transform: translateX(-50%) translateY(-2rpx) scale(1.04);
    box-shadow: 0 16rpx 34rpx rgba(255, 188, 35, 0.58), 0 0 0 12rpx rgba(255, 222, 109, 0.18), inset 0 -4rpx 8rpx rgba(196, 110, 9, 0.12);
  }

  60% {
    transform: translateX(-50%) translateY(0) scale(1);
    box-shadow: 0 14rpx 28rpx rgba(255, 188, 35, 0.48), 0 0 0 6rpx rgba(255, 222, 109, 0.1), inset 0 -5rpx 9rpx rgba(196, 110, 9, 0.14);
  }
}

@keyframes spin {
  from {
    transform: rotate(0);
  }

  to {
    transform: rotate(360deg);
  }
}

@keyframes messageTickerMarquee {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(-50%);
  }
}

