/* ========== 评估强提醒弹窗 ========== */

.assessOverlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.assessPopup {
  width: 620rpx;
  background: #F5F8E9;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  overflow: hidden;
}

.assessIllustration {
  width: 100%;
  display: block;
}

.assessContentLayer {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 52rpx;
  z-index: 2;
}

.assessCard {
  width: calc(100% - 80rpx);
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.assessCardTitle {
  font-size: 38rpx;
  font-weight: 800;
  color: #15934D;
  text-align: center;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

.assessDivider {
  width: 100%;
  height: 2rpx;
  background: #D4E5C7;
  margin: 22rpx 0;
  opacity: 0.6;
}

.assessCardBody {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.assessCardText {
  font-size: 30rpx;
  color: #444444;
  text-align: center;
  line-height: 1.7;
  padding: 0 8rpx;
}

.assessPrimaryBtn {
  width: calc(100% - 80rpx);
  height: 96rpx;
  margin-top: 24rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #3EA24F, #2E8B47);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 96rpx;
  text-align: center;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 71, 0.3);
  letter-spacing: 2rpx;
}

.assessPrimaryBtn::after {
  display: none;
}

.assessLaterLink {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #8C9196;
  text-align: center;
  line-height: 1;
  padding: 12rpx 24rpx;
  letter-spacing: 1rpx;
}

.assessCloseBtn {
  margin-top: 36rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.assessCloseIcon {
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
}
