.devicePreviewMetaRow {
  margin-top: 14rpx;
  align-items: flex-end;
}

.devicePreviewAlarm {
  font-size: var(--ab-font-size-min);
  color: var(--ab-color-text-1);
}

.devicePreviewTime {
  flex-shrink: 0;
  font-size: var(--ab-font-size-sm);
  color: var(--ab-color-text-2);
}

.ghostWideBtn {
  margin-top: 20rpx;
  background: #FFFFFF;
  color: var(--ab-color-text-1);
  border: 1rpx solid var(--ab-color-border);
}

/* ============ SOS 求助结果覆盖层 ============ */
.sosResultOverlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
  padding: 32rpx;
  animation: sosOverlayFadeIn 0.3s ease;
}

@keyframes sosOverlayFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.sosResultCard {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.18);
  animation: sosCardSlideUp 0.35s ease;
}

@keyframes sosCardSlideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 顶部绿色成功条 */
.sosResultTopBar {
  background: linear-gradient(135deg, #0E8946 0%, #0ba360 100%);
  padding: 36rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.sosResultCheckmark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
  animation: sosCheckPop 0.4s ease 0.15s both;
}

@keyframes sosCheckPop {
  0%   { transform: scale(0); opacity: 0; }
  60%  { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.sosResultTopTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.4;
}

/* 核心话术 */
.sosResultNotice {
  padding: 28rpx 32rpx 20rpx;
}

.sosResultNoticeText {
  font-size: 28rpx;
  line-height: 1.7;
  color: #333;
}

/* 工单信息卡片 */
.sosTicketCard {
  margin: 0 32rpx 20rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.sosTicketRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #E8ECF0;
}

.sosTicketRow:last-child {
  border-bottom: none;
}

.sosTicketLabel {
  font-size: 26rpx;
  color: #8C9196;
  flex-shrink: 0;
  width: 120rpx;
}

.sosTicketValue {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.sosTicketNo {
  font-family: 'Courier New', monospace;
  color: #0E8946;
  font-weight: 600;
}

/* 状态徽章 */
.sosStatusBadge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.sosStatus-pending {
  background: #FFF3E0;
  color: #E65100;
}

.sosStatus-processing {
  background: #E3F2FD;
  color: #0D47A1;
}

.sosStatus-handled {
  background: #E8F5E9;
  color: #1B5E20;
}

.sosStatus-closed {
  background: #F3F3F3;
  color: #666;
}

.sosStatus-default {
  background: #F3F3F3;
  color: #999;
}

/* 提示信息 */
.sosResultHint {
  padding: 0 32rpx 24rpx;
}

.sosResultHint text {
  font-size: 24rpx;
  color: #8C9196;
  line-height: 1.6;
}

/* 按钮组 */
.sosResultActions {
