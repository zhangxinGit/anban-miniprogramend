.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(236rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(247, 198, 83, 0.16), transparent 30%),
    radial-gradient(circle at top left, rgba(29, 132, 102, 0.18), transparent 36%),
    linear-gradient(180deg, #eef6ef 0%, #f6f0e7 52%, #f8f7f2 100%);
}

.stateWrap {
  min-height: 56vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 40rpx;
}

.stateSpinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(29, 132, 102, 0.12);
  border-top-color: #1d8466;
  animation: spin 800ms linear infinite;
}

.stateText {
  font-size: 26rpx;
  line-height: 1.7;
  color: #607068;
  text-align: center;
}

.stateButton {
  min-width: 240rpx;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1d8466 0%, #0d6b55 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.skeletonWrap {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeletonHero,
.skeletonTitle,
.skeletonAvatar,
.skeletonLine,
.skeletonCard {
  position: relative;
  overflow: hidden;
  background: #e9eeeb;
}

.skeletonHero::after,
.skeletonTitle::after,
.skeletonAvatar::after,
.skeletonLine::after,
.skeletonCard::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, rgba(233, 238, 235, 0) 0%, rgba(255, 255, 255, 0.78) 50%, rgba(233, 238, 235, 0) 100%);
  animation: skeletonShimmer 1.2s ease-in-out infinite;
}

.skeletonHero {
  height: 316rpx;
  border-radius: 30rpx;
}

.skeletonBlock {
  padding: 26rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(26, 81, 65, 0.06);
  box-shadow: 0 12rpx 30rpx rgba(43, 56, 50, 0.06);
}

.skeletonTitle {
  width: 260rpx;
  height: 38rpx;
  border-radius: 12rpx;
}

.skeletonRow {
  margin-top: 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.skeletonAvatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.skeletonLines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-top: 6rpx;
}

.skeletonLine {
  height: 24rpx;
  border-radius: 10rpx;
}

.skeletonLineMain {
  width: 86%;
}

.skeletonLineSub {
  width: 62%;
}

.skeletonGrid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.skeletonCard {
  height: 170rpx;
  border-radius: 24rpx;
}

@keyframes skeletonShimmer {
  100% {
    transform: translateX(100%);
  }
}

.homeShell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.heroSection {
  position: relative;
  padding-bottom: 0;
}

.heroSwiper {
  height: 316rpx;
}

.heroCard {
  position: relative;
  height: 100%;
  padding: 26rpx 28rpx 30rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(50, 58, 45, 0.12);
  overflow: hidden;
}

.heroImage {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.heroShade {
  position: absolute;
  inset: 0;
}

.heroCard.brand .heroShade {
  background:
    linear-gradient(90deg, rgba(17, 52, 50, 0.82) 0%, rgba(17, 52, 50, 0.56) 44%, rgba(17, 52, 50, 0.18) 100%),
    linear-gradient(180deg, rgba(0, 0, 0, 0.06) 0%, rgba(0, 0, 0, 0.24) 100%);
}

.heroCard.science .heroShade {
  background:
    linear-gradient(90deg, rgba(37, 63, 79, 0.84) 0%, rgba(37, 63, 79, 0.52) 46%, rgba(37, 63, 79, 0.12) 100%),
    linear-gradient(180deg, rgba(0, 0, 0, 0.04) 0%, rgba(0, 0, 0, 0.2) 100%);
}

.heroCard.welfare .heroShade {
  background:
    linear-gradient(90deg, rgba(79, 54, 28, 0.84) 0%, rgba(79, 54, 28, 0.54) 48%, rgba(79, 54, 28, 0.14) 100%),
    linear-gradient(180deg, rgba(0, 0, 0, 0.03) 0%, rgba(0, 0, 0, 0.18) 100%);
}

.heroCard.brand .heroImage {
  object-position: center 34%;
}

.heroCard.science .heroImage {
  object-position: center 42%;
}

.heroCard.welfare .heroImage {
  object-position: center 46%;
}

.heroContent {
  position: relative;
  z-index: 1;
  max-width: 68%;
  padding-top: 2rpx;
}

.heroCard::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  pointer-events: none;
}

.heroBadge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 19rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.heroTitle {
  margin-top: 14rpx;
  max-width: 430rpx;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: 0.4rpx;
  text-shadow: 0 5rpx 16rpx rgba(0, 0, 0, 0.24);
}

.heroSubtitle {
  margin-top: 12rpx;
  max-width: 390rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.18);
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.heroDots {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.heroDot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(23, 120, 89, 0.18);
  transition: all 180ms ease;
}

.heroDotActive {
  width: 34rpx;
  background: #8cd1ab;
}

.heroActions {
  position: relative;
  z-index: 2;
  margin: -74rpx 18rpx 0;
}

.heroActionsPanel {
  display: flex;
  gap: 18rpx;
  padding: 14rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 255, 255, 0.88) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 42rpx rgba(39, 52, 46, 0.12);
}

.heroPrimaryButton,
.heroGhostButton,
.benefitButton,
.sosFloatButton,
.stateButton {
  border: 0;
}

.heroPrimaryButton::after,
.heroGhostButton::after,
.benefitButton::after,
.sosFloatButton::after,
.stateButton::after {
  display: none;
}

.heroPrimaryButton,
.heroGhostButton {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: none;
}

.heroPrimaryButton {
  background: linear-gradient(135deg, #da5546 0%, #bc3d37 100%);
  color: #ffffff;
}

.heroGhostButton {
  background: rgba(244, 247, 246, 0.98);
  color: #20403b;
}

.sectionBlock {
  padding: 26rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(26, 81, 65, 0.06);
  box-shadow: 0 12rpx 30rpx rgba(43, 56, 50, 0.06);
}

.homeMessageSection {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.homeServiceSection {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.sectionBlockLast {
  margin-bottom: 10rpx;
}

.sectionHeader {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.sectionHeaderCompact {
  gap: 0;
}

.sectionTitle {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #20302a;
}

.sectionDesc {
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f7f74;
}

.messagePanel {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
}

.messageRow {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx 0;
}

.messageRow + .messageRow {
  border-top: 1rpx solid rgba(29, 61, 50, 0.08);
}

.messageRowIcon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
}

.messageRowBody {
  flex: 1;
  min-width: 0;
}

.messageRowHead {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.messageRowTitle {
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #26322b;
}

.messageRowBadge {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #ffefef;
  color: #ef6a63;
  font-size: 18rpx;
  line-height: 1.2;
  font-weight: 700;
}

.messageTickerCompact {
  margin-top: 8rpx;
  overflow: hidden;
  white-space: nowrap;
}

.messageTickerCompact .messageTickerItem {
  padding: 0;
}

.messageTickerCompact .messageTickerText {
  padding-left: 0;
  padding-right: 10rpx;
  font-size: 25rpx;
  color: #68786f;
}

.messageTickerCompact .messageTickerDivider {
  padding: 0 22rpx 0 0;
  font-size: 24rpx;
  color: #9aaca2;
}

.messageRowText {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #68786f;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.messageRowTextMuted {
  color: #7b8b82;
}

.messageGrid {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
}

.messageCard {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 216rpx;
  padding: 16rpx 16rpx;
  border-radius: 24rpx;
  color: #24312b;
}

.messageCardEmpty {
  min-height: 176rpx;
}

.messageCard.alarm {
  background: linear-gradient(180deg, #edf7f1 0%, #f9fdfb 100%);
}

.messageCard.help {
  background: linear-gradient(180deg, #fff1ec 0%, #fff9f7 100%);
}

.messageCard.notice {
  background: linear-gradient(180deg, #eef3fa 0%, #fafcff 100%);
}

.messageCardHeader {
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.messageIcon {
  position: relative;
  width: 176rpx;
  height: 94rpx;
  padding: 0 16rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-weight: 800;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(20, 38, 31, 0.08);
  box-sizing: border-box;
  flex-shrink: 0;
}

.messageIconText {
  font-size: 28rpx;
  line-height: 1.2;
}

.messageCard.alarm .messageIcon {
  background: linear-gradient(135deg, #2e8f69 0%, #1d7a56 100%);
}

.messageCard.help .messageIcon {
  background: linear-gradient(135deg, #dc6952 0%, #bf3f3d 100%);
}

.messageCard.notice .messageIcon {
  background: linear-gradient(135deg, #5074ae 0%, #3d5f98 100%);
}

.messageDot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff564f;
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
  box-shadow: 0 0 0 5rpx rgba(255, 86, 79, 0.14);
}

.messageList {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.messageTicker {
  margin-top: 18rpx;
  width: 100%;
  overflow: hidden;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.46);
  border: 1rpx solid rgba(80, 116, 174, 0.08);
}

.messageTickerTrack {
  display: flex;
  align-items: center;
  width: max-content;
  min-width: 100%;
  animation: messageTickerMarquee 14s linear infinite;
}

.messageTickerItem {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 0;
}

.messageTickerText {
  flex-shrink: 0;
  padding-left: 22rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: #4f5d56;
  white-space: nowrap;
}

.messageTickerDivider {
  flex-shrink: 0;
  padding: 0 30rpx 0 18rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  color: #5074ae;
  white-space: nowrap;
}

.messageLine,
.messageEmpty,
.messageFooter {
  font-size: 21rpx;
  line-height: 1.6;
}

.messageLine {
  color: #4f5d56;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.messageEmpty {
  margin-top: 16rpx;
  color: #7a8881;
}

.messageFooter {
  margin-top: auto;
  padding-top: 14rpx;
  color: #2d6c5c;
  font-weight: 700;
}

.messageCard.notice .messageFooter {
  transform: translateY(-6px);
}

.messageCardEmpty .messageFooter {
  width: 176rpx;
  align-self: center;
  margin-top: 12rpx;
  padding-top: 0;
  text-align: center;
}

.featureGrid {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  column-gap: 18rpx;
  row-gap: 16rpx;
}

.featureGridModern {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.featureServiceCard {
  position: relative;
  width: calc((100% - 16rpx) / 2);
  min-height: 176rpx;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
  display: flex;
  align-items: flex-end;
}

.featureServiceCard.green {
  background: linear-gradient(135deg, #3bce7d 0%, #14b05e 100%);
}

.featureServiceCard.blue {
  background: linear-gradient(135deg, #4b8fff 0%, #386dda 100%);
}

.featureServiceCard.orange {
  background: linear-gradient(135deg, #ff9c4a 0%, #f17f27 100%);
}

.featureServiceCard.red {
  background: linear-gradient(135deg, #f67a68 0%, #ea554a 100%);
}

.featureServiceCard::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.04) 0%, rgba(0, 0, 0, 0.02) 52%, rgba(255, 255, 255, 0) 100%);
}

.featureServiceBody {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 2;
  padding-right: 114rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.featureServiceTitle {
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.featureServiceSubtitle {
  font-size: 19rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.82);
}

.featureServiceAction {
  align-self: flex-start;
  margin-top: 10rpx;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  font-size: 20rpx;
  line-height: 42rpx;
  font-weight: 700;
}

.featureServiceCard.green .featureServiceAction {
  color: #159654;
}

.featureServiceCard.blue .featureServiceAction {
  color: #3d6fdd;
}

.featureServiceCard.orange .featureServiceAction {
  color: #f07d25;
}

.featureServiceCard.red .featureServiceAction {
  color: #e6584e;
}

.featureServiceImage {
  position: absolute;
  right: 4rpx;
  bottom: 2rpx;
  z-index: 1;
  width: 128rpx;
  height: 128rpx;
  background-repeat: no-repeat;
  background-position: center bottom;
  background-size: contain;
  pointer-events: none;
}

.featureServiceImageAssessment {
  right: 0;
  bottom: 0;
  width: 116rpx;
  height: 146rpx;
}

.featureServiceImageDevice {
  right: 8rpx;
  bottom: 2rpx;
  width: 110rpx;
  height: 138rpx;
}

.featureServiceImageHousekeeping {
  right: -8rpx;
  bottom: -2rpx;
  width: 140rpx;
  height: 136rpx;
}

.featureServiceImageRenovation {
  right: 6rpx;
  bottom: 0;
  width: 112rpx;
  height: 142rpx;
}

