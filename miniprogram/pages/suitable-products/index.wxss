.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #f5f6f8;
}

/* 搜索栏 */
.searchBar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #ffffff;
  gap: 20rpx;
}

.searchInputWrap {
  display: flex;
  align-items: center;
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f6f8;
  border-radius: 36rpx;
}

.searchIcon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><circle cx='28' cy='28' r='16' fill='none' stroke='%23999999' stroke-width='4'/><line x1='40' y1='40' x2='54' y2='54' stroke='%23999999' stroke-width='4' stroke-linecap='round'/></svg>") center/contain no-repeat;
  flex-shrink: 0;
}

.searchInput {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 72rpx;
}

/* 头部购物车入口 */
.headerCart {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.headerCartIcon {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f6f8;
  border-radius: 50%;
}

.headerCartBadge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 14rpx;
  background: #FF6B35;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}

/* 分类标签 */
.categoryScroll {
  background: #ffffff;
  white-space: nowrap;
  padding-bottom: 16rpx;
}

.categoryList {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.categoryTag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f6f8;
  white-space: nowrap;
  flex-shrink: 0;
}

.categoryTag.active {
  background: #07C160;
  color: #ffffff;
  font-weight: 700;
}

/* 商品网格 — 双列 */
.productGrid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.productCard {
  width: calc(50% - 10rpx);
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.productImage {
  width: 100%;
  height: 340rpx;
  display: block;
  background: #f0f0f0;
}

.productInfo {
  padding: 16rpx 20rpx 20rpx;
}

.productName {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.productSpec {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.3;
}

.productBottom {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.productPrice {
  display: flex;
  align-items: baseline;
}

.priceSymbol {
  font-size: 22rpx;
  color: #FF6B35;
  font-weight: 700;
}

.priceValue {
  font-size: 36rpx;
  color: #FF6B35;
  font-weight: 800;
  line-height: 1;
}

.addBtn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #07C160;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
}

/* 加载状态 */
.loadingRow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.loadingText {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.emptyIcon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.emptyText {
  font-size: 28rpx;
  color: #999;
}

/* 底部购物车栏 — 始终可见 */
.cartBar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
  box-sizing: border-box;
}

.cartBarLeft {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.cartBarIcon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cartIconInner {
  width: 36rpx;
  height: 36rpx;
  background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><path fill='%23ffffff' d='M20 16l-4-8H6l4 8 4 28a4 4 0 0 0 4 4h28a4 4 0 0 0 4-4l4-20H20zm2 32a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm20 0a4 4 0 1 0 0 8 4 4 0 0 0 0-8z'/></svg>") center/contain no-repeat;
}

.cartBadge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: #FF6B35;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}

.cartBarTotal {
  display: flex;
  align-items: baseline;
}

.cartBarTotalLabel {
  font-size: 26rpx;
  color: #666;
}

.cartBarTotalPrice {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF6B35;
}

.cartBarEmpty {
  font-size: 26rpx;
  color: #bbb;
}

.cartBarBtn {
  height: 64rpx;
  padding: 0 36rpx;
  border-radius: 32rpx;
  background: #07C160;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cartBarBtn.disabled {
  background: #d9d9d9;
  color: #999;
}
