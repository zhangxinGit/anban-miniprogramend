.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom)); /* iOS 11.0-11.2 */
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
}

/* 空状态 */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.emptyIcon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.emptyTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.emptySub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 36rpx;
}

.emptyBtn {
  width: 200rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #07C160;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 购物车头部 */
.cartHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
  background: #ffffff;
}

.cartHeaderTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.cartClearBtn {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

/* 购物车列表 */
.cartList {
  padding: 0 24rpx;
}

.cartItem {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 16rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  margin-top: 16rpx;
  position: relative;
}

.cartItemImage {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.cartItemInfo {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.cartItemName {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.cartItemSpec {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.cartItemBottom {
  margin-top: 16rpx;
}

.cartItemPrice {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.cartItemPrice .priceSymbol {
  font-size: 22rpx;
  color: #FF6B35;
  font-weight: 700;
}

.cartItemPrice .priceValue {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: 800;
  line-height: 1;
}

.quantityControl {
  display: inline-flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}

.qtyBtn {
  width: 56rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  background: #f5f6f8;
}

.qtyValue {
  width: 64rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  background: #ffffff;
}

.cartItemSubtotal {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
}

.cartItemDelete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 底部下单栏 */
.cartFooter {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  /* 底部安全区域适配 */
  padding-bottom: constant(safe-area-inset-bottom); /* iOS 11.0-11.2 */
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
  box-sizing: border-box;
}

.cartFooterLeft {
  flex: 1;
}

.cartFooterSummary {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.cartFooterCount {
  font-size: 24rpx;
  color: #999;
}

.cartFooterLabel {
  font-size: 26rpx;
  color: #666;
}

.cartFooterPrice {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF6B35;
}

.cartFooterBtn {
  height: 64rpx;
  padding: 0 40rpx;
  border-radius: 32rpx;
  background: #07C160;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
