.page {
  min-height: 100vh;
  padding: 22rpx 24rpx 34rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #EDF5EA 0%, #F6FAF3 24%, #FFFFFF 100%);
}

.fadeIn {
  animation: fadeIn 240ms ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.header {
  padding: 8rpx 4rpx 20rpx;
}

.title {
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #202321;
}

.sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #7B867E;
  line-height: 1.4;
}

.card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 24rpx 22rpx 26rpx;
  box-shadow: 0 20rpx 44rpx rgba(47, 74, 39, 0.06);
}

.guideTitle,
.sectionTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #202321;
}

.guideText {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.58;
  color: #727C74;
}

.referralNotice {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #FFF5E8;
  color: #8F5C1D;
  font-size: 24rpx;
  line-height: 1.5;
}

.formList {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.formItem {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.formLabel {
  font-size: 25rpx;
  line-height: 1.4;
  color: #59635C;
  font-weight: 600;
}

.formInput {
  width: 100%;
  min-height: 82rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E4EAE2;
  background: #FFFFFF;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #283029;
}

.formInputError {
  border-color: #E35A4A !important;
  animation: formShake 450ms ease;
}

.formItemShake .formLabel {
  color: #E35A4A;
}

@keyframes formShake {
  0%, 100% { transform: translateX(0); }
  15% { transform: translateX(-10rpx); }
  30% { transform: translateX(10rpx); }
  45% { transform: translateX(-8rpx); }
  60% { transform: translateX(8rpx); }
  75% { transform: translateX(-4rpx); }
  90% { transform: translateX(4rpx); }
}

.genderRow {
  display: flex;
  gap: 14rpx;
}

.genderChip {
  flex: 1;
  min-height: 82rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E4EAE2;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #556057;
  font-weight: 600;
}

.genderChipActive {
  border-color: #9DD1AE;
  background: #F7FBF8;
  color: #0E8946;
  box-shadow: inset 0 0 0 1rpx rgba(14, 137, 70, 0.12);
}

.profileSummary {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.profileSummaryText {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F0F7F2;
  color: #0E8946;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 600;
}

.progressRow {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.progressBar {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #E2ECE0;
}

.progressInner {
  height: 100%;
  border-radius: 999rpx;
  background: #0E8946;
  transition: width 180ms ease;
}

.progressText {
  font-size: 22rpx;
  color: #8B938D;
}

.questionTitle {
  margin-top: 22rpx;
  font-size: 30rpx;
  line-height: 1.48;
  font-weight: 700;
  color: #252825;
}

.optionList {
  margin-top: 18rpx;
}

.optionItem {
  display: flex;
  align-items: center;
  min-height: 72rpx;
  margin-bottom: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid #E4EAE2;
  border-radius: 16rpx;
  background: #FFFFFF;
  transition: all 160ms ease;
}

.optionItemActive {
  border-color: #9DD1AE;
  background: #F7FBF8;
  box-shadow: inset 0 0 0 1rpx rgba(14, 137, 70, 0.12);
}

.optionText {
  font-size: 27rpx;
  color: #454B45;
}

.surveyActions {
  margin-top: 22rpx;
  display: flex;
  gap: 12rpx;
}

.secondaryButton,
.primaryButton,
.outlineButton,
.retryButton {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.secondaryButton::after,
.primaryButton::after,
.outlineButton::after,
.retryButton::after {
  display: none;
}

.secondaryButton {
  flex: 1;
  background: #F7F8F5;
  color: #717972;
  border: 1rpx solid #E4E9E1;
}

.primaryButton {
  flex: 1;
  background: #F3F5F1;
  color: #B1B8B2;
}

.primaryButtonActive {
  background: #0E8946;
  color: #FFFFFF;
}

.fullButton {
  width: 100%;
  flex: none;
  margin-top: 32rpx;
}

.outlineButton {
  width: 100%;
  background: #F0F7F2;
  color: #0E8946;
  border: 1rpx solid #B7DEC4;
}

.secondaryButton[disabled] {
  background: #F3F5F1;
  color: #B1B8B2;
  border-color: #EEF1EC;
}

.primaryButton[disabled],
.secondaryButton[disabled] {
  opacity: 1;
}

.resultCard {
  padding-bottom: 22rpx;
}

.riskRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.riskBadge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.riskBadgeIcon,
.riskBadgeText {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.riskScore {
  font-size: 26rpx;
  color: #868C87;
}

.sectionBlock {
  margin-top: 24rpx;
}

.adviceItem,
.emptyCard {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #F6F7F4;
  font-size: 26rpx;
  line-height: 1.5;
  color: #555D57;
}

.leadCard {
  margin-top: 10rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: #EEF5F0;
  display: flex;
  gap: 14rpx;
}

.leadStatusText {
  min-width: 168rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #434944;
  font-weight: 600;
}

.leadIdWrap {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.45;
  color: #818B83;
  word-break: break-all;
}

.leadIdLabel,
.leadIdValue {
  font-size: 24rpx;
  color: #818B83;
}

.historyRow {
  display: grid;
  grid-template-columns: 160rpx 1fr auto;
  align-items: center;
  column-gap: 10rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #EEF1ED;
}

.historyRow:last-child {
  border-bottom: none;
}

.historyTime {
  font-size: 22rpx;
  color: #969C97;
}

.historyRisk {
  justify-self: center;
  font-size: 26rpx;
  font-weight: 700;
}

.historyScore {
  font-size: 24rpx;
  color: #909690;
}

.resultActions {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.stateText {
  font-size: 28rpx;
  color: #78827A;
}

.retryButton {
  width: 240rpx;
  background: #0E8946;
  color: #FFFFFF;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(0, 0, 0, 0.12);
  border-top-color: rgba(14, 137, 70, 0.7);
  animation: spin 800ms linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0);
  }
  to {
    transform: rotate(360deg);
  }
}

