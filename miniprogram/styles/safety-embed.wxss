/* 嵌在首页的居家安全模块（与「安全自查」页样式对齐，受 .home-safety 作用域保护） */
.home-safety {
  position: relative;
}
.home-safety .header {
  padding: 4rpx 8rpx 22rpx;
}
.home-safety .header .title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1f2a20;
}
.home-safety .header .sub {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #7b8a7d;
  line-height: 1.6;
}
.home-safety .safetyCard {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0, #ffffff 100%);
  border-radius: 30rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(21, 147, 77, 0.08);
  box-shadow: 0 16rpx 34rpx rgba(15, 64, 35, 0.06);
}
.home-safety .guideTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a20;
}
.home-safety .guideText {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #7b8a7d;
  line-height: 1.7;
}
.home-safety .progressWrap {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.home-safety .progressBar {
  flex: 1;
  height: 16rpx;
  background: #e5ede4;
  border-radius: 999rpx;
  overflow: hidden;
  margin-right: 18rpx;
}
.home-safety .progressInner {
  height: 16rpx;
  background: linear-gradient(135deg, #28c56e 0%, #15934d 100%);
  border-radius: 999rpx;
  transition: width 180ms ease;
}
.home-safety .progressText {
  font-size: 22rpx;
  color: #7b8a7d;
}
.home-safety .qWrap {
  margin-top: 28rpx;
}
.home-safety .qTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a20;
  line-height: 1.55;
}
.home-safety .qScore {
  margin-left: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #7b8a7d;
}
.home-safety .options {
  margin-top: 22rpx;
}
.home-safety .opt {
  border: 1rpx solid #e3ece4;
  border-radius: 22rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  transition: all 160ms ease;
}
.home-safety .optActive {
  border-color: rgba(21, 147, 77, 0.24);
  background: #f6faf7;
  box-shadow: 0 10rpx 24rpx rgba(21, 147, 77, 0.08);
}
.home-safety .optText {
  font-size: 26rpx;
  color: #1f2a20;
}
.home-safety .safetyActions {
  margin-top: 24rpx;
  display: flex;
  gap: 18rpx;
}
.home-safety .safetyActions.col {
  flex-direction: column;
  margin-top: 30rpx;
}
.home-safety .primary {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #28c56e 0%, #15934d 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.home-safety .primary[disabled] {
  background: #eef2ed;
  color: #b2bbb3;
}
.home-safety .primary.full {
  width: 100%;
  flex: none;
}

/* 「重新测评」降低引导性：弱化为次要操作（与自查页一致） */
.home-safety .reAssessBtn {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  color: #1f2a20;
  font-size: 26rpx;
  font-weight: 700;
  border: 1rpx solid #e3ece4;
}
.home-safety .reAssessBtn::after {
  display: none;
}
.home-safety .primary.outline {
  background: #FFFFFF;
  color: #1f2a20;
  border: 1rpx solid #e3ece4;
}
.home-safety .ghost {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #f5f7f4;
  color: #5c6b60;
  font-size: 26rpx;
}

.home-safety .ghost[disabled] {
  background: #eef2ed;
  color: #b2bbb3;
}
.home-safety .riskHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.home-safety .riskBadge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
}
.home-safety .riskIcon {
  color: #fff;
  font-size: 30rpx;
}
.home-safety .riskText {
  color: #fff;
  font-size: 28rpx;
  font-weight: 750;
}
.home-safety .riskScore {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2a20;
}
.home-safety .secBlock {
  margin-top: 30rpx;
}
.home-safety .secTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2a20;
  margin-bottom: 18rpx;
}
.home-safety .tip {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: #f6faf7;
  border: 1rpx solid #e3ece4;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #1f2a20;
  line-height: 1.65;
}
.home-safety .safetyEmpty {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: #f6faf7;
  font-size: 22rpx;
  color: #7b8a7d;
}
.home-safety .historyRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 6rpx;
  border-bottom: 1rpx solid #edf1ec;
}
.home-safety .historyTime {
  font-size: 22rpx;
  color: #7b8a7d;
}
.home-safety .historyRisk {
  font-size: 22rpx;
  font-weight: 600;
}
.home-safety .historyScore {
  font-size: 22rpx;
  color: #7b8a7d;
}
