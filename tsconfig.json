{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@mp/*": ["miniprogram/*"]
    }
  },
  "include": ["miniprogram/**/*.ts", "shared/**/*.ts"]
}
